# ─────────────────────────────────────────────────────────────
# LATUSHYA — Frontend Environment Variables
# Copy to .env.local for local overrides (optional — Vite proxy
# handles the backend URL automatically in development).
# ─────────────────────────────────────────────────────────────

# ─── Backend API URL ─────────────────────────────────────────
# Leave empty in development — Vite proxy forwards /api/* to
# http://localhost:5000 automatically (see vite.config.js).
#
# In production (Vercel), set this to your deployed backend URL:
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=

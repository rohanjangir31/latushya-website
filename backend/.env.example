# ─────────────────────────────────────────────────────────────
# LATUSHYA — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────────────
# Get from: MongoDB Atlas → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
DB_NAME=latushya

# ─── Frontend (CORS) ─────────────────────────────────────────
# Your Vercel production URL — added to the CORS allowlist
# e.g. https://latushya.vercel.app
FRONTEND_URL=https://your-project.vercel.app

# ─── Auth — Phase 2 ──────────────────────────────────────────
# Uncomment and fill when implementing authentication
# JWT_SECRET=replace_with_a_long_random_string_minimum_32_chars
# JWT_EXPIRES_IN=7d
# ADMIN_EMAIL=admin@latushya.com
# ADMIN_PASSWORD=replace_with_strong_password_before_seeding

# ─── Email / Resend — Phase 2 ────────────────────────────────
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Latushya <noreply@latushya.com>
# ADMIN_NOTIFY_EMAIL=owner@latushya.com

# ─── Cloudinary — Phase 3 ────────────────────────────────────
# Get from: https://console.cloudinary.com/
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
